# UoPeople Moodle credentials
MOODLE_USERNAME=your_uopeople_username
MOODLE_PASSWORD=your_uopeople_password
MOODLE_URL=https://my.uopeople.edu

# Notion API credentials
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# Timezone (IANA format)
TIMEZONE=Asia/Dhaka

# Priority thresholds (in hours)
URGENT_HOURS=24
SOON_HOURS=72
